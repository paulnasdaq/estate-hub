<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Activate your {{ company_name }} account</title>
</head>
<body style="margin:0;background:#efece4;font-family:'Helvetica Neue',-apple-system,Arial,sans-serif;color:#201d1a;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#efece4;padding:32px 0;">
    <tr>
      <td align="center">
        <table role="presentation" width="480" cellpadding="0" cellspacing="0" style="width:480px;max-width:100%;background:#fbfaf6;border-radius:6px;overflow:hidden;">
          <tr>
            <td style="padding:40px 40px 24px;">
              <p style="margin:0 0 20px;font-size:15px;line-height:1.6;">Hi {{ name }},</p>
              <p style="margin:0 0 20px;font-size:15px;line-height:1.6;">
                An account has been created for you at {{ company_name }}. Set a
                password to activate it and sign in.
              </p>
              <p style="margin:28px 0;">
                <a href="{{ activation_url }}"
                   style="display:inline-block;background:#201d1a;color:#fbfaf6;text-decoration:none;padding:12px 22px;border-radius:5px;font-size:14px;font-weight:600;">
                  Activate your account
                </a>
              </p>
              <p style="margin:0 0 8px;font-size:13px;line-height:1.6;color:#6b6459;">
                This link expires in {{ ttl_hours }} hours. If you didn't expect
                this, you can ignore this email.
              </p>
              <p style="margin:16px 0 0;font-size:12px;line-height:1.6;color:#6b6459;word-break:break-all;">
                If the button doesn't work, paste this into your browser:<br>
                {{ activation_url }}
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
