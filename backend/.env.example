# Copy to .env and adjust for your environment. Do not commit real secrets.
APP_NAME=backend
ENVIRONMENT=local
LOG_LEVEL=INFO

# Local default (SQLite). For Postgres use the psycopg driver, e.g. via Docker:
DATABASE_URL=sqlite:///./app.db
# DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/app

# Used by docker-compose.prod.yml (interpolated into DATABASE_URL and Postgres).
# POSTGRES_USER=app
# POSTGRES_PASSWORD=change-me
# POSTGRES_DB=app
